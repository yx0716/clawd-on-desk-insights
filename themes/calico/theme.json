{
  "schemaVersion": 1,
  "name": "Calico",
  "author": "rullerzhou",
  "version": "1.0.0",
  "description": "A calico cat desk pet — AI-generated APNG animations",
  "license": "MIT",

  "viewBox": { "x": 0, "y": 0, "width": 266, "height": 200 },

  "eyeTracking": {
    "enabled": false
  },

  "states": {
    "idle":         ["calico-idle.apng"],
    "yawning":      ["calico-yawning.apng"],
    "dozing":       ["calico-dozing.apng"],
    "collapsing":   ["calico-collapsing.apng"],
    "thinking":     ["calico-thinking.apng"],
    "working":      ["calico-working-typing.apng"],
    "juggling":     ["calico-working-juggling.apng"],
    "sweeping":     ["calico-working-sweeping.apng"],
    "error":        ["calico-error.apng"],
    "attention":    ["calico-happy.apng"],
    "notification": ["calico-notification.apng"],
    "carrying":     ["calico-working-carrying.apng"],
    "sleeping":     ["calico-sleeping.apng"],
    "waking":       ["calico-waking.apng"]
  },

  "workingTiers": [
    { "minSessions": 3, "file": "calico-working-building.apng" },
    { "minSessions": 2, "file": "calico-working-juggling.apng" },
    { "minSessions": 1, "file": "calico-working-typing.apng" }
  ],

  "jugglingTiers": [
    { "minSessions": 2, "file": "calico-working-conducting.apng" },
    { "minSessions": 1, "file": "calico-working-juggling.apng" }
  ],

  "idleAnimations": [],

  "displayHintMap": {
    "clawd-working-building.svg": "calico-working-building.apng",
    "clawd-working-typing.svg":   "calico-working-typing.apng",
    "clawd-working-juggling.svg": "calico-working-juggling.apng",
    "clawd-working-conducting.svg": "calico-working-conducting.apng",
    "clawd-working-thinking.svg": "calico-thinking.apng"
  },

  "timings": {
    "minDisplay": {
      "attention": 4000,
      "error": 5000,
      "sweeping": 5500,
      "notification": 2500,
      "carrying": 3000,
      "working": 1000,
      "thinking": 1000
    },
    "autoReturn": {
      "attention": 4000,
      "error": 5000,
      "sweeping": 300000,
      "notification": 2500,
      "carrying": 3000
    },
    "yawnDuration": 3000,
    "wakeDuration": 1500,
    "deepSleepTimeout": 600000,
    "mouseIdleTimeout": 20000,
    "mouseSleepTimeout": 60000
  },

  "hitBoxes": {
    "default":  { "x": 80, "y": 30, "w": 106, "h": 140 },
    "sleeping": { "x": 60, "y": 60, "w": 146, "h": 100 },
    "wide":     { "x": 50, "y": 20, "w": 166, "h": 160 }
  },
  "wideHitboxFiles": ["calico-error.apng", "calico-notification.apng", "calico-working-conducting.apng"],
  "sleepingHitboxFiles": ["calico-sleeping.apng", "calico-collapsing.apng"],

  "reactions": {
    "drag":       { "file": "calico-react-drag.apng" },
    "clickLeft":  { "file": "calico-react-poke.apng", "duration": 2500 },
    "clickRight": { "file": "calico-react-poke.apng", "duration": 2500 }
  },

  "miniMode": {
    "supported": true,
    "offsetRatio": 0.5,
    "states": {
      "mini-idle":        ["calico-mini-idle.apng"],
      "mini-alert":       ["calico-mini-alert.apng"],
      "mini-happy":       ["calico-mini-happy.apng"],
      "mini-enter":       ["calico-mini-enter.apng"],
      "mini-peek":        ["calico-mini-peek.apng"],
      "mini-crabwalk":    ["calico-mini-crabwalk.apng"],
      "mini-enter-sleep": ["calico-mini-sleep.apng"],
      "mini-sleep":       ["calico-mini-sleep.apng"]
    },
    "timings": {
      "minDisplay": { "mini-alert": 4000, "mini-happy": 4000 },
      "autoReturn": { "mini-alert": 4000, "mini-happy": 4000 }
    },
    "glyphFlips": {}
  },

  "sounds": {
    "complete": "complete.mp3",
    "confirm":  "confirm.mp3"
  },

  "objectScale": {
    "widthRatio":  1.4,
    "heightRatio": 1.2,
    "offsetX":    -0.2,
    "offsetY":    -0.05
  }
}
